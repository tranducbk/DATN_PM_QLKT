{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "build": "tsc && cp -r src/generated dist/generated",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "serve": "npm run build && pm2 start ecosystem.config.js",
    "restart": "npm run build && pm2 restart be-qlkt",
    "dev": "tsx watch src/index.ts",
    "init-super-admin": "tsx src/scripts/initSuperAdmin.ts",
    "setup": "prisma db push && npm run init-super-admin",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "seed:reset": "prisma db execute --file scripts/demo/00-reset-all.sql --schema prisma/schema.prisma",
    "seed:ui": "prisma db execute --file scripts/demo/01-seed-data.sql --schema prisma/schema.prisma",
    "seed:eligibility": "prisma db execute --file scripts/demo/02-seed-eligibility.sql --schema prisma/schema.prisma",
    "seed:fresh": "npm run seed:reset && npm run seed:ui",
    "seed:demo-passwords": "tsx scripts/demo/02-set-passwords.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.4",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "fs": "^0.0.1-security",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.15.0",
    "pg": "^8.16.3",
    "pm2": "^5.4.3",
    "prisma": "^6.17.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.8.1",
    "prisma-erd-generator": "^2.1.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
